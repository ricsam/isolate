{
  "name": "@ricsam/isolate",
  "version": "0.1.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./daemon": {
      "import": "./src/daemon.ts",
      "types": "./src/daemon.ts"
    }
  },
  "bin": {
    "isolate-daemon": "./src/daemon.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --test --experimental-strip-types 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-replace": "^6.0.0",
    "linkedom": "^0.18.12",
    "mime-types": "^3.0.2",
    "rollup": "^4.0.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^24",
    "playwright": "^1",
    "typescript": "^5"
  },
  "peerDependencies": {
    "isolated-vm": "^6",
    "playwright": "^1"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  }
}
